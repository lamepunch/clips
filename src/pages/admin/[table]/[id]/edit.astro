---
import { eq, getTableColumns } from "drizzle-orm";
import Base from "@/layouts/Base.astro";
import AdminFields from "@/components/AdminFields.astro";
import { formValues, getAdminTable, primaryKey } from "@/lib/admin";

const { db } = Astro.locals;
const { table: name, id } = Astro.params;
const table = getAdminTable(name);
if (!table || !id) return new Response("Not found", { status: 404 });

const [pkKey, pkCol] = primaryKey(table);

let error: string | null = null;
if (Astro.request.method === "POST") {
  const values = formValues(table, await Astro.request.formData());
  try {
    // ponytail: generic admin over a table union — full typing isn't worth it.
    await db
      .update(table as never)
      .set(values as never)
      .where(eq(pkCol, id));
    return Astro.redirect(`/admin/${name}`);
  } catch (err) {
    error = err instanceof Error ? err.message : String(err);
  }
}

const row = (await db
  .select()
  .from(table as never)
  .where(eq(pkCol, id))
  .get()) as Record<string, unknown> | undefined;
if (!row) return new Response("Not found", { status: 404 });

const cols = getTableColumns(table);
---

<Base title={`Admin · edit ${name}`}>
  <p><a href={`/admin/${name}`}>← {name}</a></p>
  <h1>Edit {name} <small>{String(row[pkKey])}</small></h1>
  {error && <p style="color:#c00;">{error}</p>}
  <form method="POST" style="max-width:480px;">
    <AdminFields cols={cols} row={row} />
    <button type="submit">Save</button>
  </form>
</Base>
